#!/usr/bin/env bash
set -euo pipefail

# Load cargo env if not already on PATH
if ! command -v cargo &>/dev/null; then
  source "$HOME/.cargo/env"
fi

echo "--- fmt ---"
cargo fmt --check
echo "--- clippy ---"
cargo clippy --all-targets -- -D warnings
echo "--- build (release) ---"
cargo build --release
echo "--- test ---"
cargo test

if command -v bash &>/dev/null; then
  echo "--- completions smoke ---"
  bash tests/completions_smoke.sh
fi

echo "pre-commit: ok"
