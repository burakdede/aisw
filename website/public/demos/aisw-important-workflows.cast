[6.76,"o","\u001b[36m\u001b[1mInitialize aisw\u001b[0m\r\n\u001b[2m───────────────\u001b[0m\r\n\r\n  \u001b[2mHome          :\u001b[0m /tmp/aisw-demo/home/.aisw\r\n\r\n\u001b[1mShell integration\u001b[0m\r\n  \u001b[2mShell         :\u001b[0m bash\r\n  \u001b[2mAppended to /tmp/aisw-demo/home/.bashrc. Restart your shell or run: source /tmp/aisw-demo/home/.bashrc\u001b[0m\r\n\r\n\u001b[1mDetected tools\u001b[0m\r\n  \u001b[2maisw checked your PATH for supported coding agent CLIs.\u001b[0m\r\n\r\n\u001b[1mClaude Code\u001b[0m\r\n  \u001b[2mStatus        :\u001b[0m detected\r\n  \u001b[2mVersion       :\u001b[0m claude 1.0.0\r\n  \u001b[2mPath          :\u001b[0m /tmp/aisw-demo/bin/claude\r\n\r\n\u001b[1mCodex CLI\u001b[0m\r\n  \u001b[2mStatus        :\u001b[0m detected\r\n  \u001b[2mVersion       :\u001b[0m codex 1.0.0\r\n  \u001b[2mPath          :\u001b[0m /tmp/aisw-demo/bin/codex\r\n\r\n\u001b[1mGemini CLI\u001b[0m\r\n  \u001b[2mStatus        :\u001b[0m not detected\r\n\r\n\u001b[1mCredential onboarding\u001b[0m\r\n  \u001b[2mEach tool is checked for existing live credentials that can be imported into aisw.\u001b[0m\r\n\r\n\u001b[1mClaude Code\u001b[0m\r\n  \u001b[2mDetected      :\u001b[0m yes\r\n  \u001b[2mCredentials   :\u001b[0m not found\r\n\r\n\u001b[1mCodex CLI\u001b[0m\r\n  \u001b[2mDetected      :\u001b[0m yes\r\n  \u001b[2mCredentials   :\u001b[0m found /tmp/aisw-demo/home/.codex/auth.json\r\n  \u001b[2mAuth          :\u001b[0m \u001b[36moauth\u001b[0m\r\n\u001b[33m\u001b[1mCould not verify whether codex OAuth profile 'default' belongs to a distinct account identity.\u001b[0m\r\n\u001b[32m\u001b[1mImported Codex CLI credentials as profile 'default' and marked it active.\u001b[0m\r\n  \u001b[2mImport        :\u001b[0m profile 'default'\r\n  \u001b[2mActivation    :\u001b[0m \u001b[32mactive\u001b[0m\r\n\r\n\u001b[1mGemini CLI\u001b[0m\r\n  \u001b[2mDetected      :\u001b[0m no\r\n  \u001b[2mCredentials   :\u001b[0m not found\r\n\r\n\u001b[36m\u001b[1mSetup complete\u001b[0m\r\n\u001b[2m──────────────\u001b[0m\r\n\r\n\u001b[36m\u001b[1mNext\u001b[0m\r\n  \u001b[36mRun 'aisw list' to review profiles, then 'aisw use <tool> <name>' to switch.\u001b[0m\r\n"]
